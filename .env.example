# Supabase PostgreSQL (backend). Use your real password; keep .env out of git.
# For Render: use "Connection pooling" URI (port 6543), not direct (5432), to avoid ENETUNREACH.
# Supabase → Project Settings → Database → Connection pooling → URI (Transaction mode).
# Example pooler: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# Backend API URL. Frontend uses this to call the API.
# Local: backend on port 4000. Deployed: your backend URL (e.g. https://mg-fitness-api.railway.app)
VITE_API_URL=http://localhost:4000

# Optional: Supabase project URL (for future use, e.g. Auth or Storage)
# SUPABASE_URL=https://mjyeaoquuzeszfxgvtyd.supabase.co
